# Copia este archivo a .env y rellena valores (nunca subas .env al repo).
# En Windows PowerShell: Copy-Item .env.example .env

# --- JWT (ejemplo; usar claves seguras en real) ---
# JWT_SECRET=cambiar-por-clave-larga-y-aleatoria
# JWT_EXPIRATION_MS=86400000

# --- Bases de datos (un bloque por servicio cuando existan) ---
# AUTH_DB_URL=jdbc:postgresql://localhost:5432/auth
# AUTH_DB_USER=auth
# AUTH_DB_PASSWORD=auth

# USER_DB_URL=jdbc:postgresql://localhost:5433/users
# USER_DB_USER=users
# USER_DB_PASSWORD=users

# --- URLs entre servicios (local / Docker) ---
# USER_SERVICE_URL=http://localhost:8082
# AUTH_SERVICE_URL=http://localhost:8081
